# Required keys
export DEEPSEEK_API_KEY="sk-REPLACE_ME"
export VOLCANO_ARK_API_KEY="ark-REPLACE_ME"
export LITELLM_MASTER_KEY="sk-litellm-local-REPLACE_ME"

# Optional: force ALL incoming requests (including cx <model>) to one route.
# WARNING: 启用后 cx 指定的模型也会被覆盖，日常使用应保持注释。
# 仅在需要把所有流量（含 Codex subagent 自发请求）统一指向一个后端时打开。
# export LITELLM_FORCE_PROXY_MODEL="kimi-k2.6"

# Optional: volcano tool slimming knobs (for InvalidParameter tuning)
# default max tools is 12; set 0 to disable cap
# export VOLCANO_MAX_TOOLS="12"
# default max description chars is 4000; set 0 to disable truncation
# export VOLCANO_TOOL_DESC_MAX_CHARS="4000"
